@page "/summary"
@using PetSitterApp.Models
@using PetSitterApp.Services
@using System.Globalization
@inject LocalDbService LocalDbService

<style>
    @@media (max-width: 599px) {
        .summary-tabs .mud-tab {
            font-size: 0 !important;
            min-width: unset !important;
            padding: 6px 12px !important;
        }
        .summary-tabs .mud-tab .mud-icon-root {
            font-size: 24px !important;
            margin-right: 0 !important;
        }
    }

    /* Prevent iOS callout/selection popups on chart interaction */
    .summary-chart-container {
        -webkit-touch-callout: none;
        -webkit-user-select: none;
        user-select: none;
    }

    /* Style the line chart to have an "area" style fill */
    .mud-charts-line-series path:nth-of-type(1) {
        fill: rgba(41, 121, 255, 0.2) !important;
    }
    .mud-charts-line-series path:nth-of-type(2) {
        fill: rgba(29, 233, 182, 0.2) !important;
    }
</style>

<MudContainer MaxWidth="MaxWidth.Large" Class="mt-4">
    <MudText Typo="Typo.h4" GutterBottom="true">Financial Summary</MudText>

    <MudGrid Class="mb-2">
        <MudItem xs="6" sm="4" md="3">
            <MudDatePicker Label="Start Date" Date="_startDate" DateChanged="OnStartDateChanged" Editable="false" DateFormat="yyyy-MM-dd" PickerVariant="PickerVariant.Dialog" />
        </MudItem>
        <MudItem xs="6" sm="4" md="3">
            <MudDatePicker @ref="_endDatePicker" Label="End Date" Date="_endDate" DateChanged="OnEndDateChanged" Editable="false" DateFormat="yyyy-MM-dd" PickerVariant="PickerVariant.Dialog" MinDate="_startDate" />
        </MudItem>
        <MudItem xs="12">
            <MudButtonGroup Variant="Variant.Outlined" OverrideStyles="false">
                <MudButton OnClick="SetThisYear">This Year</MudButton>
                <MudButton OnClick="SetLastYear">Last Year</MudButton>
                <MudButton OnClick="SetLast3Months">Last 3 Months</MudButton>
            </MudButtonGroup>
        </MudItem>
    </MudGrid>

    @if (_loading)
    {
        <MudProgressCircular Indeterminate="true" />
    }
    else
    {
        <MudTabs Elevation="0" Rounded="true" ApplyEffectsToContainer="true" PanelClass="pa-0" Class="mt-4 summary-tabs">
            <MudTabPanel Text="Data" Icon="@Icons.Material.Filled.TableRows">
                <MudTable Items="@_tableData" Hover="true" Breakpoint="Breakpoint.None" Elevation="0">
                    <HeaderContent>
                        <MudTh>Month</MudTh>
                        <MudTh>Expected</MudTh>
                        <MudTh>Paid</MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd DataLabel="Month">@context.MonthLabel</MudTd>
                        <MudTd DataLabel="Expected">@context.Expected.ToString("C")</MudTd>
                        <MudTd DataLabel="Paid">@context.Paid.ToString("C")</MudTd>
                    </RowTemplate>
                </MudTable>
            </MudTabPanel>
            <MudTabPanel Text="Graph" Icon="@Icons.Material.Filled.BarChart">
                <MudGrid>
                    <MudItem xs="12" md="8" Class="summary-chart-container">
                        <MudStack Row="true" Justify="Justify.Center" Spacing="4" Class="mb-0">
                            <MudText Typo="Typo.subtitle1">Expected: <b>@_totalExpected.ToString("C")</b></MudText>
                            <MudText Typo="Typo.subtitle1">Paid: <b style="color: var(--mud-palette-success);">@_totalPaid.ToString("C")</b></MudText>
                        </MudStack>
                        <MudChart ChartType="ChartType.Line" MatchBoundsToSize="true" ChartOptions="_chartOptions" ChartSeries="@_series" ChartLabels="@_xAxisLabels" Width="100%" Height="350px" @bind-SelectedIndex="_selectedChartIndex" />
                    </MudItem>
                </MudGrid>
            </MudTabPanel>
        </MudTabs>
    }
</MudContainer>

@code {
    public class MonthlySummaryData
    {
        public DateTime MonthDate { get; set; }
        public string MonthLabel { get; set; } = "";
        public double Expected { get; set; }
        public double Paid { get; set; }
    }

    private List<MonthlySummaryData> _tableData = new();
    private int _selectedChartIndex = -1;
    private DateTime? _startDate = new DateTime(DateTime.Now.Year, 1, 1);
    private DateTime? _endDate = new DateTime(DateTime.Now.Year, 12, 31);
    private List<ChartSeries<double>> _series = new();
    private string[] _xAxisLabels = Array.Empty<string>();
    private bool _loading = false;
    private double _totalExpected = 0;
    private double _totalPaid = 0;
    private MudDatePicker _endDatePicker;
    private System.Threading.CancellationTokenSource? _debounceCts;
    private LineChartOptions _chartOptions = new LineChartOptions
    {
        InterpolationOption = InterpolationOption.Straight,
        LineStrokeWidth = 8,
        XAxisLabelRotation = 45,
        ShowDataMarkers = true
    };

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private void DebounceLoadData()
    {
        _debounceCts?.Cancel();
        _debounceCts = new System.Threading.CancellationTokenSource();
        var token = _debounceCts.Token;

        _ = Task.Run(async () =>
        {
            await Task.Delay(1000, token);
            if (!token.IsCancellationRequested)
            {
                await InvokeAsync(async () => await LoadData());
            }
        }, token);
    }

    private async Task LoadData()
    {
        _loading = true;
        StateHasChanged();

        try
        {
            var appointments = await LocalDbService.GetAppointments();
            var payments = await LocalDbService.GetPayments();

            ProcessData(appointments, payments);
        }
        finally
        {
            _loading = false;
        }
    }

    private void OnStartDateChanged(DateTime? date)
    {
        _startDate = date;
        if (_startDate.HasValue)
        {
            var targetDate = _startDate.Value.AddMonths(3);
            var daysInMonth = DateTime.DaysInMonth(targetDate.Year, targetDate.Month);
            _endDate = new DateTime(targetDate.Year, targetDate.Month, daysInMonth);

            if (_endDatePicker != null)
            {
                _endDatePicker.PickerMonth = _endDate.Value;
            }
        }
        DebounceLoadData();
    }

    private void OnEndDateChanged(DateTime? date)
    {
        _endDate = date;
        DebounceLoadData();
    }

    private async Task SetThisYear()
    {
        _startDate = new DateTime(DateTime.Now.Year, 1, 1);
        _endDate = new DateTime(DateTime.Now.Year, 12, 31);
        await LoadData();
    }

    private async Task SetLastYear()
    {
        var lastYear = DateTime.Now.Year - 1;
        _startDate = new DateTime(lastYear, 1, 1);
        _endDate = new DateTime(lastYear, 12, 31);
        await LoadData();
    }

    private async Task SetLast3Months()
    {
        _endDate = new DateTime(DateTime.Now.Year, DateTime.Now.Month, 1).AddMonths(1).AddDays(-1);
        _startDate = new DateTime(DateTime.Now.Year, DateTime.Now.Month, 1).AddMonths(-2);
        await LoadData();
    }

    private void ProcessData(List<Appointment> appointments, List<Payment> payments)
    {
        if (_startDate == null || _endDate == null) return;

        var start = _startDate.Value;
        // Ensure we cover the entire end day
        var end = _endDate.Value.Date.AddDays(1).AddTicks(-1);

        var labels = new List<string>();
        var expectedData = new List<double>();
        var paidData = new List<double>();
        var tableDataList = new List<MonthlySummaryData>();

        var current = new DateTime(start.Year, start.Month, 1);
        var endMonth = new DateTime(end.Year, end.Month, 1);

        // Filter appointments based on End date within the overall range
        var validAppointments = appointments
            .Where(a => !a.IsDeleted && a.End.HasValue
                        && a.End.Value >= start && a.End.Value <= end)
            .ToList();

        // Valid payments are those linked to an appointment that falls in the date range
        // We exclude Write off payments as before
        var validAppointmentIds = validAppointments.Select(a => a.Id).ToHashSet();
        var validPayments = payments
            .Where(p => !p.IsDeleted && validAppointmentIds.Contains(p.AppointmentId)
                        && !string.Equals(p.Method, "Write off", StringComparison.OrdinalIgnoreCase))
            .ToList();

        while (current <= endMonth)
        {
            var nextMonth = current.AddMonths(1);

            // Label
            if (start.Year != end.Year)
            {
                labels.Add(current.ToString("MMM yyyy"));
            }
            else
            {
                labels.Add(current.ToString("MMM"));
            }

            // Month Appointments (based on End date)
            var monthAppointments = validAppointments
                .Where(a => a.End.Value >= current && a.End.Value < nextMonth)
                .ToList();

            // Expected amount for this month
            var monthExpected = monthAppointments.Sum(a => (double)a.ExpectedAmount);
            expectedData.Add(monthExpected);

            // Paid amount for appointments ending in this month
            var monthAppointmentIds = monthAppointments.Select(a => a.Id).ToHashSet();
            var monthPaid = validPayments
                .Where(p => monthAppointmentIds.Contains(p.AppointmentId))
                .Sum(p => (double)p.Amount);

            paidData.Add(monthPaid);

            tableDataList.Add(new MonthlySummaryData
            {
                MonthDate = current,
                MonthLabel = current.ToString("MMM yy"),
                Expected = monthExpected,
                Paid = monthPaid
            });

            current = nextMonth;
        }

        // Sort table data newest to oldest
        _tableData = tableDataList.OrderByDescending(d => d.MonthDate).ToList();

        _totalExpected = expectedData.Sum();
        _totalPaid = paidData.Sum();

        _xAxisLabels = labels.ToArray();
        _series = new List<ChartSeries<double>>
        {
            new ChartSeries<double> { Name = "Expected", Data = expectedData.ToArray() },
            new ChartSeries<double> { Name = "Paid", Data = paidData.ToArray() }
        };
    }
}
